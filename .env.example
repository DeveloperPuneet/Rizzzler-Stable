PORT=3000
BASE_URL=https://your-app.onrender.com

MONGO_URI=your_mongodb_connection_string
SESSION_SECRET=generate_a_long_random_string_here

# ---------- Multi-cluster file storage (requirement #6) ----------
# MONGO_URI is always the primary/coordinator cluster (Users, Settings,
# sessions, and the FileLocation routing table all live here).
# Add more Atlas clusters purely as extra file-storage capacity by
# setting MONGO_URI_2, MONGO_URI_3, ... — nothing else needs to change,
# the storage router (config/storageRouter.js) picks them up automatically.
# Each defaults to a 512MB budget (Atlas free tier); override per-cluster
# with e.g. MONGO_URI_2_CAPACITY_MB=1024 for a bigger paid cluster.
MONGO_URI_2=
# MONGO_URI_2_CAPACITY_MB=512

# ---------- Mail ----------
# Checked in this order, first fully-configured one wins:
#   1) Gmail API (OAuth2)  -- real Google, works on Render's free tier (HTTPS)
#   2) Brevo HTTPS API     -- fallback, also HTTPS-based
#   3) Raw SMTP            -- last resort, works locally, usually BLOCKED
#                              outbound on Render's free tier (SMTP ports
#                              25/465/587 are firewalled there)

# --- Option 1: Gmail API (recommended for Render) ---
# See README "Gmail API setup" for how to obtain these from Google Cloud
# Console + OAuth Playground.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=your_gmail_address@gmail.com

# --- Option 2: Brevo (fallback) ---
BREVO_API_KEY=
BREVO_SENDER_EMAIL=

# --- Option 3: Raw SMTP (local dev fallback) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_gmail_app_password
MAIL_FROM="your_gmail_address@gmail.com"

ADMIN_PASSWORD=Puneet2010@

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
