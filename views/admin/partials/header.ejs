<body class="rz-admin-body">
  <div class="rz-admin-shell">
    <button type="button" class="rz-admin-menu-btn" id="rzAdminMenuBtn" aria-label="Toggle menu">☰</button>

    <aside class="rz-admin-sidebar" id="rzAdminSidebar">
      <a href="/admin" class="rz-admin-brand">
        <img src="/images/logo.png" alt="Rizzzler" />
        <span>Rizzzler <em>Admin</em></span>
      </a>
      <nav class="rz-admin-nav">
        <a href="/admin"
          class="<%= typeof activeNav !== 'undefined' && activeNav === 'dashboard' ? 'rz-admin-nav-active' : '' %>">📊
          Dashboard</a>
        <a href="/admin/users"
          class="<%= typeof activeNav !== 'undefined' && activeNav === 'users' ? 'rz-admin-nav-active' : '' %>">👥
          Users</a>
        <a href="/admin/analytics"
          class="<%= typeof activeNav !== 'undefined' && activeNav === 'analytics' ? 'rz-admin-nav-active' : '' %>">📈
          Analytics</a>
        <a href="/admin/security"
          class="<%= typeof activeNav !== 'undefined' && activeNav === 'security' ? 'rz-admin-nav-active' : '' %>">🛡️
          Security</a>
        <a href="/admin/settings"
          class="<%= typeof activeNav !== 'undefined' && activeNav === 'settings' ? 'rz-admin-nav-active' : '' %>">⚙️
          Customize / Mail</a>
      </nav>
      <div class="rz-admin-sidebar-footer">
        <a href="/" target="_blank" class="rz-admin-view-site">↗ View live site</a>
        <form action="/admin/logout" method="POST">
          <button type="submit" class="rz-admin-logout-btn">Log out</button>
        </form>
      </div>
    </aside>

    <main class="rz-admin-main">