<body class="rz-admin-body">
  <div class="rz-admin-auth-wrapper">
    <div class="rz-auth-blob rz-auth-blob--1" style="background:#ff4d4d;"></div>
    <section class="rz-admin-auth-card rz-admin-blocked-card">
      <div class="rz-admin-blocked-icon">🚫</div>
      <h2>Access permanently blocked</h2>
      <p class="rz-muted">
        Too many incorrect admin password attempts were made from this device/network.
        This device is now permanently blocked from accessing the admin panel.
      </p>
    </section>
  </div>
