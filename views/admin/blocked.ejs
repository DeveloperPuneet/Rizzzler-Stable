  <meta name="robots" content="noindex, nofollow" />
  <meta name="theme-color" content="#06060e" />
  <title>Access Blocked — Rizzzler</title>
  <link rel="icon" type="image/png" href="/images/logo.png" />
  <link rel="stylesheet" href="/css/main.css" />
