<% pageTitle = (profile.displayName || profile.username) + " — Rizzzler" %>
<% const themeKey = theme.key || 'darknights'; %>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#06060e" />
  <meta name="description" content="<%= typeof metaDescription !== 'undefined' && metaDescription ? metaDescription : 'A stylish Rizzzler showcase page with links, media, and a custom theme.' %>" />
  <meta name="keywords" content="<%= typeof metaKeywords !== 'undefined' && metaKeywords ? metaKeywords : 'Rizzzler, showcase page, profile links' %>" />
  <meta property="og:type" content="profile" />
  <meta property="og:title" content="<%= pageTitle %>" />
  <meta property="og:description" content="<%= typeof metaDescription !== 'undefined' && metaDescription ? metaDescription : 'A stylish Rizzzler showcase page with links, media, and a custom theme.' %>" />
  <meta property="og:image" content="<%= baseUrl %>/images/logo.png" />
  <meta property="og:url" content="<%= typeof canonicalUrl !== 'undefined' ? canonicalUrl : currentUrl %>" />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content="<%= pageTitle %>" />
  <meta name="twitter:description" content="<%= typeof metaDescription !== 'undefined' && metaDescription ? metaDescription : 'A stylish Rizzzler showcase page with links, media, and a custom theme.' %>" />
  <meta name="twitter:image" content="<%= baseUrl %>/images/logo.png" />
  <link rel="canonical" href="<%= typeof canonicalUrl !== 'undefined' ? canonicalUrl : currentUrl %>" />
  <title><%= pageTitle %></title>
  <link rel="icon" type="image/png" href="/images/logo.png" />
  <link rel="stylesheet" href="/css/main.css" />
  <link rel="stylesheet" href="/css/showcase-base.css" />
  <% if (theme.css) { %>
    <link rel="stylesheet" href="<%= theme.css %>" />
  <% } %>
  <style>
    html, body { width:100%; margin:0; padding:0; overflow-x:hidden; }
    body { background:#000; font-family:'Segoe UI',Roboto,sans-serif; display:block; }
    .rz-showcase { width:100vw; min-width:100vw; position:relative; display:block; margin:0; padding:0; }
    .rz-showcase-bg { position:fixed; inset:0; z-index:0; pointer-events:none; }
    .rz-section { position:relative; width:100%; min-height:100vh; display:flex; align-items:center; justify-content:center; overflow:hidden; z-index:1; margin:0; padding:56px clamp(20px, 4vw, 56px); }
    .rz-section-content { position:relative; z-index:2; width:min(100%, 1100px); margin:0 auto; }
    .rz-showcase-footer { position:fixed; bottom:18px; left:50%; transform:translateX(-50%); color:rgba(255,255,255,0.28); font-size:11px; letter-spacing:2px; text-transform:uppercase; z-index:10; backdrop-filter:blur(12px); padding:6px 14px; border-radius:999px; background:rgba(0,0,0,0.35); pointer-events:none; }
    .rz-showcase-audio { position:fixed; left:-9999px; top:-9999px; width:1px; height:1px; opacity:0; pointer-events:none; }
    .rz-hero-banner { position:absolute; inset:-10vh 0 0 0; background-size:cover; background-position:center; background-repeat:no-repeat; will-change:transform; }
    .rz-hero-overlay { position:absolute; inset:0; z-index:1; }
    .rz-hero-content { position:relative; z-index:2; text-align:center; max-width:820px; padding:48px 20px; }
    .rz-hero-avatar-wrap { display:flex; justify-content:center; margin-bottom:24px; }
    .rz-hero-avatar { width:150px; height:150px; object-fit:cover; border-radius:50%; border:4px solid rgba(255,255,255,0.9); box-shadow:0 18px 50px rgba(0,0,0,0.35); }
    .rz-grand-text { font-size:clamp(2.8rem, 7vw, 5.6rem); font-weight:900; text-align:center; text-transform:uppercase; margin:0; line-height:1.02; letter-spacing:0.06em; }
    .rz-image-wrapper { position:absolute; inset:0; overflow:hidden; }
    .rz-image-wrapper img { width:100%; height:100%; object-fit:cover; }
    .rz-floating-particles { position:fixed; inset:0; z-index:0; pointer-events:none; }
    .rz-filler-divider { position:absolute; inset:0; pointer-events:none; }
    .rz-hero-name { font-size:clamp(2.4rem, 5vw, 3.8rem); margin:16px 0 10px; font-weight:800; }
    .rz-hero-username, .rz-hero-views { font-size:1.05rem; margin:8px 0; opacity:0.9; }
    .rz-hero-badge { display:inline-flex; align-items:center; gap:8px; padding:8px 16px; border-radius:999px; background:rgba(255,255,255,0.14); backdrop-filter:blur(8px); }
    .rz-story-grid { display:grid; grid-template-columns:1.2fr 0.8fr; gap:24px; align-items:center; }
    .rz-story-card { padding:24px 28px; border-radius:28px; background:rgba(255,255,255,0.12); backdrop-filter:blur(12px); box-shadow:0 20px 45px rgba(0,0,0,0.2); }
    .rz-links-grid { display:grid; grid-template-columns:repeat(2, minmax(180px, 1fr)); gap:14px; }
    .rz-link-item { display:block; padding:16px 18px; border-radius:18px; text-align:center; font-weight:700; letter-spacing:0.04em; }
    .rz-details-row { display:grid; grid-template-columns:repeat(auto-fit, minmax(180px, 1fr)); gap:14px; }
    .rz-detail-item { padding:16px 18px; border-radius:18px; background:rgba(255,255,255,0.1); }
    .rz-credits-logo { font-size:clamp(3rem, 8vw, 6.2rem); font-weight:900; text-transform:uppercase; letter-spacing:0.16em; }
    @media (max-width: 700px) { .rz-story-grid { grid-template-columns:1fr; } .rz-links-grid { grid-template-columns:1fr; } }
  </style>
</head>
<body>
<div class="rz-page-loader" id="pageLoader" aria-hidden="true">
  <div class="rz-loader-card">
    <div class="rz-loader-logo-wrap">
      <img src="/images/logo.png" alt="Rizzzler logo" class="rz-loader-logo" />
    </div>
    <div class="rz-loader-text">Loading showcase…</div>
    <div class="rz-loader-bar"><span></span></div>
  </div>
</div>
<div class="rz-showcase rz-theme-<%= themeKey %>">
  <div class="rz-showcase-bg"></div>
  <div class="rz-floating-particles" id="floatingParticles"></div>

  <section class="rz-section rz-hero-section" id="heroSection">
    <div class="rz-hero-banner" id="heroBanner"
      <% if (profile.banner && profile.banner.fileId) { %>
        style="background-image:url('/file/<%= profile.banner.fileId %>')"
      <% } else { %>
        style="background: linear-gradient(135deg, #2a0a4a, #000)"
      <% } %>
    ></div>
    <div class="rz-hero-overlay"></div>
    <div class="rz-hero-content">
      <div class="rz-hero-avatar-wrap">
        <% if (profile.avatar && profile.avatar.fileId) { %>
          <img src="/file/<%= profile.avatar.fileId %>" class="rz-hero-avatar" alt="avatar" />
        <% } else { %>
          <div class="rz-hero-avatar" style="background:var(--accent); display:flex; align-items:center; justify-content:center; font-size:48px; color:#000;">
            <%= (profile.displayName || profile.username).charAt(0).toUpperCase() %>
          </div>
        <% } %>
      </div>
      <div class="rz-hero-badge">✦ <%= theme.heroEyebrow || 'The Legend' %></div>
      <h1 class="rz-hero-name"><%= profile.displayName || profile.username %></h1>
      <% if (profile.showLegacyBadge && profile.legacyNumber) { %>
        <span class="rz-badge">#<%= profile.legacyNumber %></span>
      <% } %>
      <p class="rz-hero-username">@<%= profile.username %></p>
      <p class="rz-hero-views">👁️ <%= profile.profileViews || 0 %> views</p>
      <% if (profile.bio) { %>
        <p class="rz-story-card" style="margin-top:20px;"><%= profile.bio %></p>
      <% } %>
    </div>
    <div class="rz-scroll-indicator">▼ Scroll ▼</div>
  </section>

  <% if (profile.showcaseImages && profile.showcaseImages.length) { %>
    <% const grandWords = (theme.grandWords && theme.grandWords.length) ? theme.grandWords : ['Fearless', 'Unstoppable', 'Radiant', 'Iconic']; %>
    <% const storyBlurbs = (theme.storyBlurbs && theme.storyBlurbs.length) ? theme.storyBlurbs : ['A little snapshot of the energy, style, and story behind this showcase.']; %>
    <% profile.showcaseImages.forEach((img, i) => { %>
      <section class="rz-section rz-image-section">
        <div class="rz-section-content rz-story-grid <%= i % 2 === 1 ? 'rz-story-grid--reverse' : '' %>">
          <div class="rz-story-card">
            <p class="rz-section-eyebrow">Moment <%= i + 1 %></p>
            <h2 class="rz-grand-text"><%= grandWords[i % grandWords.length] %></h2>
            <p class="rz-story-copy"><%= storyBlurbs[i % storyBlurbs.length] %></p>
          </div>
          <div class="rz-story-card" style="padding:0; overflow:hidden; min-height:360px;">
            <div class="rz-image-wrapper" data-parallax="0.3">
              <img src="/file/<%= img.fileId %>" alt="showcase image" loading="lazy" />
            </div>
          </div>
        </div>
      </section>
    <% }) %>
  <% } %>

  <% if (profile.links && profile.links.length) { %>
    <section class="rz-section rz-links-section">
      <div class="rz-section-content">
        <div class="rz-story-card">
          <p class="rz-section-eyebrow">Connect</p>
          <h2 class="rz-grand-text">follow the trail</h2>
          <div class="rz-links-grid" style="margin-top:24px;">
            <% profile.links.forEach(link => { %>
              <a href="<%= link.url %>" target="_blank" rel="noopener" class="rz-link-item"><%= link.label %></a>
            <% }) %>
          </div>
        </div>
      </div>
    </section>
  <% } %>

  <% const detailItems = []; if (profile.phoneNumber) { detailItems.push({ icon:'📞', value:profile.phoneNumber, href:'tel:'+profile.phoneNumber }); } if (profile.location) { detailItems.push({ icon:'📍', value:profile.location }); } if (profile.profession) { detailItems.push({ icon:'💼', value:profile.profession }); } %>
  <% if (detailItems.length) { %>
    <section class="rz-section rz-details-section">
      <div class="rz-section-content">
        <div class="rz-story-card">
          <p class="rz-section-eyebrow">Details</p>
          <div class="rz-details-row" style="margin-top:20px;">
            <% detailItems.forEach(item => { %>
              <div class="rz-detail-item">
                <div style="font-size:1.1rem; margin-bottom:8px;"><%= item.icon %></div>
                <% if (item.href) { %><a href="<%= item.href %>"><%= item.value %></a><% } else { %><span><%= item.value %></span><% } %>
              </div>
            <% }) %>
          </div>
        </div>
      </div>
    </section>
  <% } %>

  <section class="rz-section rz-credits-section">
    <div class="rz-section-content" style="text-align:center;">
      <div class="rz-credits-logo">Rizzzler</div>
      <p style="margin-top:16px; font-size:1.05rem; opacity:0.8;"><%= theme.creditsTagline || 'your one link, your whole vibe' %></p>
    </div>
  </section>
</div>

<div class="rz-showcase-footer">Rizzzler</div>

<% if (profile.audio && profile.audio.key) { %>
  <% const audioExt = (profile.audio.key.split('.').pop() || '').toLowerCase(); %>
  <% const audioMimeMap = { mp3:'audio/mpeg', wav:'audio/wav', ogg:'audio/ogg', m4a:'audio/mp4', aac:'audio/aac', weba:'audio/webm', webm:'audio/webm' }; %>
  <audio
    id="rz-bg-audio"
    preload="auto"
    <%= profile.audio.autoplay ? 'autoplay' : '' %>
    <%= profile.audio.loop ? 'loop' : '' %>
    class="rz-showcase-audio"
    aria-hidden="true"
  >
    <source src="/audios/<%= profile.audio.key %>" type="<%= audioMimeMap[audioExt] || 'audio/mpeg' %>" />
  </audio>
  <button type="button" class="rz-sound-toggle" id="rzSoundToggle" aria-label="Toggle sound" title="Toggle sound">🔊</button>
<% } %>

<script>
(function(){
  const banner = document.getElementById('heroBanner');
  window.addEventListener('scroll', () => {
    if(banner) {
      const scroll = window.scrollY;
      banner.style.transform = `translateY(${scroll * 0.35}px)`;
    }
  });

  const imageWrappers = document.querySelectorAll('.rz-image-wrapper[data-parallax]');
  window.addEventListener('scroll', () => {
    imageWrappers.forEach(w => {
      const speed = parseFloat(w.getAttribute('data-parallax') || 0.3);
      const rect = w.getBoundingClientRect();
      const center = rect.top + rect.height/2;
      const scrollCenter = window.innerHeight/2;
      const offset = (center - scrollCenter) * speed;
      const img = w.querySelector('img');
      if(img) img.style.transform = `translateY(${offset}px) scale(1.04)`;
    });
  });

  const sections = document.querySelectorAll('.rz-section');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if(entry.isIntersecting) {
        entry.target.classList.add('in-view');
      }
    });
  }, { threshold: 0.2 });
  sections.forEach(s => observer.observe(s));

  const bgAudio = document.getElementById('rz-bg-audio');
  const soundToggle = document.getElementById('rzSoundToggle');
  if (bgAudio) {
    bgAudio.addEventListener('error', () => {
      if (soundToggle) soundToggle.style.display = 'none';
    }, true);

    const tryPlay = () => {
      bgAudio.volume = 0.4;
      bgAudio.play().then(() => {
        if (soundToggle) { soundToggle.classList.remove('rz-needs-tap'); soundToggle.textContent = '🔊'; }
      }).catch(() => {
        if (soundToggle) { soundToggle.classList.add('rz-needs-tap'); soundToggle.textContent = '🔈'; }
      });
    };
    tryPlay();
    window.addEventListener('pointerdown', tryPlay, { once: true });
    window.addEventListener('keydown', tryPlay, { once: true });
    window.addEventListener('load', tryPlay, { once: true });
    setTimeout(tryPlay, 1000);

    if (soundToggle) {
      soundToggle.addEventListener('click', () => {
        if (bgAudio.paused) {
          bgAudio.play().then(() => { soundToggle.textContent = '🔊'; soundToggle.classList.remove('rz-needs-tap'); }).catch(() => {});
        } else {
          bgAudio.pause();
          soundToggle.textContent = '🔈';
        }
      });
    }
  }
})();
</script>
<script>
(function(){
  const loader = document.getElementById('pageLoader');
  if (!loader) return;

  const hide = () => {
    if (loader.classList.contains('rz-page-loader--hidden')) return;
    loader.classList.add('rz-page-loader--hidden');
    window.setTimeout(() => loader.remove(), 400);
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', hide, { once: true });
    window.addEventListener('load', hide, { once: true });
  } else {
    hide();
  }

  window.setTimeout(hide, 1800);
})();
</script>
</body>
</html>